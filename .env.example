# Google Workspace OAuth Credentials
# You can generate these in the Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# LLM & TTS API Keys
GEMINI_VERTEX_AI_CREDENTIALS="/path/to/gemini-service-account-key.json"
ELEVENLABS_API_KEY="your_elevenlabs_api_key_here"

# Database Persistence (Postgres)
# Used by LangGraph for AgentState memory checkpointer
DATABASE_URL="postgresql://user:password@localhost:5432/auricle"

# Scalable Static Context Payload
# Reference an external static prompt/persona payload for caching
USER_PROFILE_PATH="scripts/user_profile_sample.txt"
